#!/usr/bin/env php
<?php

declare(strict_types=1);

require dirname(__DIR__) . '/vendor/autoload.php';

use PrivacyScanner\Commands\ScanCommand;
use Symfony\Component\Console\Application;

$app = new Application('Privacy Scanner', '1.0.0');
$app->addCommand(new ScanCommand());
$app->setDefaultCommand('scan', true);
$app->run();
